<%- include('../partials/head', { title: title }) %>

<h1>📜 Prediction Audit Log</h1>

<div class="card" style="padding:1rem; overflow-x:auto;">

  <table class="table">

    <thead>
      <tr>
        <th>#</th>
        <th>Player</th>
        <th>Travel</th>
        <th>Selected</th>
      </tr>
    </thead>

    <tbody>

  <% logs.forEach((log, loopIndex) => { %>

    <tr>

      <td><%= loopIndex + 1 %></td>

      <td>
        <strong>
          <%= log.display_name || 'Unknown' %>
        </strong>
      </td>

      <td>
        <%= log.match_name || '-' %>
      </td>

      <td>
        <%= log.predicted_team || '-' %>
      </td>

    </tr>

  <% }) %>

</tbody>
  </table>

</div>

<%- include('../partials/foot') %>
