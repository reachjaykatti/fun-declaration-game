<%- include('../partials/head', { title: labels.matches }) %>

<h1>Bulk Import <%= labels.matches %> — <%= series.name %></h1>

<div class="card">
  <p>
    You can either <strong>upload an Excel (.xlsx) file</strong> or 
    <strong>paste travel details below</strong>.  
    Time must be provided in <strong>IST</strong> (it’ll convert internally to UTC).
  </p>

  <p style="margin:.5rem 0">
    <a href="/admin/series/<%= series.id %>/matches/bulk/template" class="btn btn-link">
      📄 Download Excel Template
    </a>
  </p>

  <!-- ✅ Upload Form (with Preview + Import buttons) -->
  <form method="POST" action="/admin/series/<%= series.id %>/matches/bulk" enctype="multipart/form-data">
    <div style="margin: .75rem 0;">
      <label for="file"><strong>Select Excel (.xlsx):</strong></label><br/>
      <input type="file" id="file" name="file" accept=".xlsx,.xls" required />
      <div class="text-muted" style="font-size:.9em;margin-top:.25rem;">
        The Excel must include columns: 
        <em>name, sport, team_a, team_b, start_time_ist, cutoff_minutes_before, entry_points</em>.
      </div>
    </div>

    <div style="margin-top:1rem;">
      <button type="submit" name="preview" value="true" class="btn btn-outline">👁 Preview</button>
      <button type="submit" class="btn btn-success">🚀 Import</button>
      <a class="btn btn-link" href="/admin/series/<%= series.id %>/matches">← Back to Travels</a>
    </div>
  </form>
</div>
let ist = r.start_time_ist;
if (typeof ist === 'number') {
  // Convert Excel serial to readable datetime in IST
  const jsDate = XLSX.SSF.parse_date_code(ist);
  ist = moment.tz(
    `${jsDate.y}-${String(jsDate.m).padStart(2, '0')}-${String(jsDate.d).padStart(2, '0')} ${String(jsDate.H).padStart(2, '0')}:${String(jsDate.M).padStart(2, '0')}`,
    'Asia/Kolkata'
  ).format('YYYY-MM-DD HH:mm');
} else {
  ist = String(ist).trim();
}

<!-- ✅ Import Results -->
<% if (result) { %>
  <div class="card" style="margin-top:1rem;">
    <h3>Import Result</h3>
    <div class="chips" style="margin-bottom:.5rem">
      <div class="chip"><span class="dot dot-ok"></span> Inserted: <strong><%= result.ok %></strong></div>
      <div class="chip"><span class="dot dot-bad"></span> Skipped: <strong><%= result.skipped %></strong></div>
    </div>

    <% if (result.errors && result.errors.length) { %>
      <div class="alert alert-warning">
        <strong>Issues:</strong>
        <ul>
          <% result.errors.forEach(e => { %>
            <li><%= e %></li>
          <% }) %>
        </ul>
      </div>
    <% } %>
  </div>
<% } %>

<!-- ✅ Preview Table -->
<% if (preview) { %>
  <hr>
  <h3>📋 Preview of First 5 Rows</h3>
  <table class="table">
    <thead>
      <tr>
        <% preview.headers.forEach(h => { %>
          <th><%= h %></th>
        <% }) %>
      </tr>
    </thead>
    <tbody>
      <% preview.rows.forEach(row => { %>
        <tr>
          <% preview.headers.forEach(h => { %>
            <td><%= row[h] || row[h.toLowerCase()] || '' %></td>
          <% }) %>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>

<%- include('../partials/foot') %>

