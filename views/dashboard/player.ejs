<%- include('../partials/head', { title: title }) %>

<h1>🏆 <%= user.display_name %> — Performance Dashboard</h1>

<div class="card">
  <p><strong>Total Points:</strong> <%= totalPoints.toFixed(2) %></p>
  <p><strong>Rank:</strong> #<%= rank %></p>
  <p><strong>Win Accuracy:</strong> <%= accuracy %>%</p>
</div>

<h2>📅 Per Travel Series Summary</h2>
<table class="table">
  <tr>
    <th>Travel</th>
    <th>Total Points</th>
    <th>Travels Participated</th>
    <th>Planned Travels</th>
  </tr>
  <% perSeries.forEach(s => { %>
  <tr>
    <td><%= s.series_name %></td>
    <td><%= s.total_points.toFixed(2) %></td>
    <td><%= s.total_travels %></td>
    <td><%= s.planned_travels %></td>
  </tr>
  <% }) %>
</table>

<!-- 📋 Detailed Match History -->
<div class="card" style="padding:1rem;overflow-x:auto;">

  <h2 style="margin-bottom:1rem;">
    📋 Travel-by-Travel Performance
  </h2>

  <table class="table">

    <thead>
      <tr>
        <th>#</th>
        <th>Travel</th>
        <th>Destinations</th>
        <th>Status</th>
        <th>Your Pick</th>
        <th>Winner</th>
        <th>Points</th>
        <th>Cumulative</th>
      </tr>
    </thead>

    <tbody>

      <% performanceTrend.forEach((m, idx) => { %>

        <tr>

          <td><%= idx + 1 %></td>

          <td><%= m.travel_name %></td>

          <td>
            <%= m.team_a %> OR <%= m.team_b %>
          </td>

          <td>
            <%= m.status %>
          </td>

          <td>
            <%= m.predicted_team || '-' %>
          </td>

          <td>
            <%= m.winner || '-' %>
          </td>

          <td
            style="
              font-weight:bold;
              color:<%= Number(m.points) >= 0 ? '#0f9d58' : '#db4437' %>;
            "
          >
            <%= Number(m.points).toFixed(2) %>
          </td>

          <td
            style="
              font-weight:bold;
              color:<%= Number(m.cumulative) >= 0 ? '#0057b8' : '#db4437' %>;
            "
          >
            <%= Number(m.cumulative).toFixed(2) %>
          </td>

        </tr>

      <% }) %>

    </tbody>

  </table>
</div>

<%- include('../partials/foot') %>
